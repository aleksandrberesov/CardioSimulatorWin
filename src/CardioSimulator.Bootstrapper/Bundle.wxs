<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal">
  <Bundle Name="CardioSimulatorWin" 
          Manufacturer="VLN Project" 
          Version="1.0.1.0" 
          UpgradeCode="a0c5c4e1-2d3a-4b6c-874a-4e897e907a3d">
    
    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication LicenseUrl="https://dotnet.microsoft.com/download/dotnet/8.0" 
                                               Theme="hyperlinkLicense" />
      
      <!-- Localization payloads for the Bootstrapper UI -->
      <Payload Name="1033\thm.wxl" SourceFile="Localization\Strings.en-us.wxl" />
      <Payload Name="1049\thm.wxl" SourceFile="Localization\Strings.ru-ru.wxl" />
      <Payload Name="2052\thm.wxl" SourceFile="Localization\Strings.zh-cn.wxl" />
      <Payload Name="3082\thm.wxl" SourceFile="Localization\Strings.es-es.wxl" />
    </BootstrapperApplication>

    <Chain>
      <!-- The app is fully self-contained (.NET runtime + Windows App SDK are bundled in
           the MSI payload), so no runtime prerequisite is chained here. -->

      <!-- The main application MSI - Select the correct one based on detected language -->
      
      <!-- Russian -->
      <MsiPackage Id="App_ruRU" SourceFile="..\CardioSimulator.Installer\bin\Release\ru-RU\CardioSimulatorWin.msi" 
                  Name="ru-RU\CardioSimulatorWin.msi"
                  Visible="no"
                  InstallCondition="WixStdBALanguageId = 1049">
          <MsiProperty Name="INSTALLFOLDER" Value="[InstallFolder]" />
      </MsiPackage>

      <!-- Chinese -->
      <MsiPackage Id="App_zhCN" SourceFile="..\CardioSimulator.Installer\bin\Release\zh-CN\CardioSimulatorWin.msi" 
                  Name="zh-CN\CardioSimulatorWin.msi"
                  Visible="no"
                  InstallCondition="WixStdBALanguageId = 2052">
          <MsiProperty Name="INSTALLFOLDER" Value="[InstallFolder]" />
      </MsiPackage>

      <!-- Spanish -->
      <MsiPackage Id="App_esES" SourceFile="..\CardioSimulator.Installer\bin\Release\es-ES\CardioSimulatorWin.msi" 
                  Name="es-ES\CardioSimulatorWin.msi"
                  Visible="no"
                  InstallCondition="WixStdBALanguageId = 3082 OR WixStdBALanguageId = 1034">
          <MsiProperty Name="INSTALLFOLDER" Value="[InstallFolder]" />
      </MsiPackage>

      <!-- English (Primary and Fallback) -->
      <MsiPackage Id="App_enUS" SourceFile="..\CardioSimulator.Installer\bin\Release\en-US\CardioSimulatorWin.msi" 
                  Name="en-US\CardioSimulatorWin.msi"
                  Visible="no"
                  InstallCondition="NOT (WixStdBALanguageId = 1049 OR WixStdBALanguageId = 2052 OR WixStdBALanguageId = 3082 OR WixStdBALanguageId = 1034)">
          <MsiProperty Name="INSTALLFOLDER" Value="[InstallFolder]" />
      </MsiPackage>
    </Chain>
  </Bundle>
</Wix>
