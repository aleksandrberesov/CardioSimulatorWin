<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CardioSimulator.App.Controls.RhythmChoosingPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CardioSimulator.App.Controls">
    <Grid Padding="8" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBox x:Name="SearchBox" Grid.Row="0" TextChanged="OnSearchChanged" />
        <ListView x:Name="List" Grid.Row="1"
                  SelectionMode="None" IsItemClickEnabled="True" ItemClick="OnItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="controls:RhythmItem">
                    <TextBlock Text="{x:Bind Title}" Foreground="{x:Bind Foreground}"
                               TextWrapping="Wrap" Padding="4,12" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
