<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CardioSimulator.App.Controls.RhythmChoosingPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CardioSimulator.App.Controls">
    <!-- Compact layout: smaller font and tighter item padding so more rhythms fit in the
         narrower left panel ("reduce blocks or font"). -->
    <Grid Padding="6" RowSpacing="6">
        <Grid.Resources>
            <!-- Section header rows in the grouped view: a contrasting band, tap to collapse/expand. -->
            <DataTemplate x:Key="RhythmHeaderTemplate" x:DataType="controls:RhythmHeader">
                <Border Background="{StaticResource AccentTintBrush}" CornerRadius="6" Margin="0,4,0,1" Padding="6,5,8,5">
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="{x:Bind Chevron}" FontSize="12"
                                  Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind Title}" FontWeight="Bold" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{x:Bind CountText}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </DataTemplate>
            <DataTemplate x:Key="RhythmItemTemplate" x:DataType="controls:RhythmItem">
                <TextBlock Text="{x:Bind Title}" Foreground="{x:Bind Foreground}"
                           FontSize="13" TextWrapping="Wrap" Padding="4,7" />
            </DataTemplate>
            <controls:RhythmRowTemplateSelector x:Key="RhythmRowSelector"
                HeaderTemplate="{StaticResource RhythmHeaderTemplate}"
                ItemTemplate="{StaticResource RhythmItemTemplate}" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: clinical-mode · list-mode toggle (groups / A-Z) · title · pin -->
        <Grid Grid.Row="0" ColumnSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ToggleButton x:Name="ClinicalToggle" Grid.Column="0" Padding="6,4" Click="OnToggleClinicalClick">
                <FontIcon x:Name="ClinicalIcon" FontSize="16" Glyph="&#xECAD;" />
            </ToggleButton>
            <Button x:Name="SortToggle" Grid.Column="1" Padding="6,4" Click="OnToggleSortClick">
                <FontIcon x:Name="SortIcon" FontSize="16" Glyph="&#xE8FD;" />
            </Button>
            <TextBlock x:Name="HeaderTitle" Grid.Column="2" VerticalAlignment="Center"
                       FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
            <ToggleButton x:Name="PinToggle" Grid.Column="3" Padding="6,4"
                          Checked="OnPinChanged" Unchecked="OnPinChanged">
                <FontIcon FontSize="16" Glyph="&#xE718;" />
            </ToggleButton>
        </Grid>

        <TextBox x:Name="SearchBox" Grid.Row="1" FontSize="13" MinHeight="0" TextChanged="OnSearchChanged" />

        <ListView x:Name="List" Grid.Row="2"
                  SelectionMode="None" IsItemClickEnabled="True" ItemClick="OnItemClick"
                  ItemTemplateSelector="{StaticResource RhythmRowSelector}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Clinical parameters dashboard shown only in clinical case presentation mode when a case is selected -->
        <Border x:Name="ClinicalDashboard" Grid.Row="3" Background="{StaticResource PanelBackgroundBrush}" 
                BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="1" CornerRadius="8" 
                Padding="12" Margin="0,6,0,0" Visibility="Collapsed">
            <StackPanel Spacing="8">
                <TextBlock x:Name="ClinicalDashboardHeader" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource AccentBrush}"/>
                <ItemsControl x:Name="ClinicalParametersList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="controls:ClinicalParameter">
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Label}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind Value}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
