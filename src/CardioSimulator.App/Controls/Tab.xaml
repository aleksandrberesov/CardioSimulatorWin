<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CardioSimulator.App.Controls.Tab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Flat, rounded clickable cell (new UI pattern). Resting look is borderless/transparent;
         ShowChevron switches it to a white "dropdown pill" with a trailing chevron; IsActive fills
         it with the accent. The chevron lives in its own column so compact (content-sized) pills
         size correctly and never overlap the label. Colors come from AppTheme. -->
    <Border x:Name="RootBorder" CornerRadius="8" Background="Transparent" MinWidth="35"
            BorderThickness="0" Padding="9,3" Tapped="OnTapped"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <FontIcon x:Name="IconView" Grid.Column="0" Grid.ColumnSpan="2" FontSize="16" Visibility="Collapsed"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
            <StackPanel x:Name="TextStack" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="TextView" TextAlignment="Center"
                           HorizontalAlignment="Center" FontSize="13" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="SubTextView" TextAlignment="Center"
                           HorizontalAlignment="Center" FontSize="9" Visibility="Collapsed" Margin="0,-3,0,0" />
            </StackPanel>
            <FontIcon x:Name="ChevronView" Grid.Column="1" Glyph="&#xE70D;" FontSize="9" Visibility="Collapsed"
                      HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0" />
        </Grid>
    </Border>
</UserControl>
