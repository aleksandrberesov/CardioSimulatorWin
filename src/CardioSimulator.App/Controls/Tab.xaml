<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CardioSimulator.App.Controls.Tab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="RootBorder" BorderBrush="Black" BorderThickness="1" CornerRadius="4"
            Background="Transparent" MinWidth="35" Tapped="OnTapped"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid>
            <FontIcon x:Name="IconView" FontSize="16" Foreground="Black" Visibility="Collapsed"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
            <StackPanel x:Name="TextStack" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="2,1">
                <TextBlock x:Name="TextView" Foreground="Black" TextAlignment="Center"
                           HorizontalAlignment="Center" FontSize="13" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="SubTextView" Foreground="Black" TextAlignment="Center"
                           HorizontalAlignment="Center" FontSize="9" Visibility="Collapsed" Margin="0,-3,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
