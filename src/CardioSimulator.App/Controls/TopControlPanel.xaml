<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CardioSimulator.App.Controls.TopControlPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CardioSimulator.App.Controls">
    <Border Background="White">
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="5*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <controls:Tab x:Name="ModeTab" Grid.Column="0" Click="OnModeClick" />
            <ContentControl x:Name="SubPanelHost" Grid.Column="1"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center" />
            <Image Grid.Column="2" Source="ms-appx:///Assets/main_logo.png" Stretch="Uniform"
                   Height="44" VerticalAlignment="Center" Margin="8,0" />
        </Grid>
    </Border>
</UserControl>
