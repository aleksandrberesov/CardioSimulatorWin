<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CardioSimulator.App.Controls.TopControlPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CardioSimulator.App.Controls">
    <Border Background="White">
        <!-- The mode block (col 0) is fixed to the left-panel width (280) so its right edge lines
             up with the rhythm-panel / monitor divider below it, forming one continuous vertical
             line down the screen. The 1px divider in col 1 draws the top segment of that line. -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <controls:Tab x:Name="ModeTab" Grid.Column="0" Click="OnModeClick" />
            <Border Grid.Column="1" Width="1" Background="#FFCCCCCC" VerticalAlignment="Stretch" />
            <ContentControl x:Name="SubPanelHost" Grid.Column="2" Margin="8,0,0,0"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center" />
            <Image Grid.Column="3" Source="ms-appx:///Assets/main_logo.png" Stretch="Uniform"
                   Height="44" VerticalAlignment="Center" Margin="8,0" />
        </Grid>
    </Border>
</UserControl>
