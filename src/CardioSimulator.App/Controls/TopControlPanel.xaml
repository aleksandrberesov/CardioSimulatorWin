<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CardioSimulator.App.Controls.TopControlPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CardioSimulator.App.Controls">
    <Border Background="Transparent">
        <!-- The mode block (col 0) is fixed to the left-panel width (280) so its right edge lines
             up with the rhythm-panel / monitor divider below it. -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <controls:Tab x:Name="ModeTab" Grid.Column="0" ShowChevron="True" MinWidth="120"
                          HorizontalAlignment="Left" VerticalAlignment="Center" Click="OnModeClick" />
            <Border Grid.Column="1" Width="8" Background="Transparent" VerticalAlignment="Stretch" />
            <ContentControl x:Name="SubPanelHost" Grid.Column="2" Margin="8,0,0,0"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center" />
            <Image Grid.Column="3" Source="ms-appx:///Assets/main_logo.png" Stretch="Uniform"
                   Height="44" VerticalAlignment="Center" Margin="8,0" />
        </Grid>
    </Border>
</UserControl>
