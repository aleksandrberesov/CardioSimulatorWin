<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CardioSimulator.App.Controls.MonitorControlPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CardioSimulator.App.Controls">
    <Grid ColumnSpacing="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="1.5*" />
            <ColumnDefinition Width="1.5*" />
            <ColumnDefinition Width="1.5*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="0.8*" />
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Display dropdowns: lead count / scheme / sweep speed / amplitude scale. -->
        <controls:Tab x:Name="CountTab" Grid.Column="0" ShowChevron="True" Click="OnCountClick" />
        <controls:Tab x:Name="SchemeTab" Grid.Column="1" ShowChevron="True" Click="OnSchemeClick" />
        <controls:Tab x:Name="SpeedTab" Grid.Column="2" ShowChevron="True" Click="OnSpeedClick" />
        <controls:Tab x:Name="ScaleTab" Grid.Column="3" ShowChevron="True" Click="OnScaleClick" />

        <Border Grid.Column="4" Width="1" Background="{StaticResource HairlineBrush}" Margin="1,4" VerticalAlignment="Stretch" />

        <!-- Electrodes (opens a window), Artifacts (dropdown), Filters (dropdown), 3D heart (opens a window). -->
        <controls:Tab x:Name="ElectrodesTab" Grid.Column="5" Click="OnElectrodesClick" />
        <controls:Tab x:Name="ArtifactsTab" Grid.Column="6" ShowChevron="True" Click="OnArtifactsClick" />
        <controls:Tab x:Name="FiltersTab" Grid.Column="7" ShowChevron="True" Click="OnFiltersClick" />
        <Border x:Name="Heart3DButton" Grid.Column="8" BorderThickness="0" CornerRadius="8"
                Background="Transparent" VerticalAlignment="Stretch" Tapped="OnHeart3DTapped"
                PointerEntered="OnHeart3DPointerEntered" PointerExited="OnHeart3DPointerExited">
            <StackPanel Orientation="Horizontal" Spacing="3"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="ms-appx:///Assets/heart_3d.png" Stretch="Uniform" Height="24" />
                <TextBlock Text="3D" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" FontSize="13"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Grid.Column="9" Width="1" Background="{StaticResource HairlineBrush}" Margin="1,4" VerticalAlignment="Stretch" />

        <!-- pQRSt: toggles the impulse/interval label overlay on the ECG graph (active = accent). -->
        <Border x:Name="PqrstButton" Grid.Column="10" BorderThickness="0" CornerRadius="8"
                Background="Transparent" VerticalAlignment="Stretch" Tapped="OnPqrstTapped">
            <TextBlock x:Name="PqrstText" Text="pQRSt" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" FontSize="15"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <!-- EOS: opens the electrical-axis window. -->
        <Border x:Name="EosButton" Grid.Column="11" BorderThickness="0" CornerRadius="8"
                Background="Transparent" VerticalAlignment="Stretch" Tapped="OnEosTapped"
                PointerEntered="OnEosPointerEntered" PointerExited="OnEosPointerExited">
            <TextBlock x:Name="EosText" Text="EOS" Foreground="Red" FontWeight="Bold" FontSize="20"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <controls:Tab x:Name="TipsTab" Grid.Column="12" Click="OnTipsClick" />

        <Border Grid.Column="13" Width="1" Background="{StaticResource HairlineBrush}" Margin="1,4" VerticalAlignment="Stretch" />

        <controls:Tab x:Name="RulerTab" Grid.Column="14" Glyph="&#xE1A0;" />
        <controls:Tab x:Name="CompareTab" Grid.Column="15" Click="OnCompareClick" />
        <controls:Tab x:Name="StartStopTab" Grid.Column="16" Click="OnStartStopClick" />
    </Grid>
</UserControl>
