<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CardioSimulator.App.Screens.MainScreen"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CardioSimulator.App.Controls">
    <!-- Edge-to-edge shell (no gray gutter frame): the monitor fills its section full width.
         Thin 1px separators keep the top/bottom bars visually distinct from the content. -->
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="15*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White" BorderBrush="#FFCCCCCC" BorderThickness="0,0,0,1">
            <controls:TopControlPanel x:Name="Top" />
        </Border>
        <Border Grid.Row="1" Background="White">
            <Grid x:Name="MiddleHost" />
        </Border>
        <Border Grid.Row="2" Background="White" BorderBrush="#FFCCCCCC" BorderThickness="0,1,0,0">
            <controls:BottomControlPanel x:Name="Bottom" />
        </Border>
    </Grid>
</UserControl>
