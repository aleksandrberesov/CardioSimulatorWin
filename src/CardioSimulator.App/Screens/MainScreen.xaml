<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CardioSimulator.App.Screens.MainScreen"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CardioSimulator.App.Controls">
    <!-- New UI pattern: a lavender page with floating control bars and the content shown in a
         white, rounded "card" (the monitor's cream paper rounds to the card corners). -->
    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <!-- Top and bottom bars both hug their content (logo + selector pills / control row)
                 instead of taking a fixed share of the window, so they stay compact strips rather
                 than ballooning with whitespace. The bottom bar's height is pinned to the top bar's
                 rendered height in code-behind so the two strips match exactly. -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="Transparent" Padding="8,0">
            <controls:TopControlPanel x:Name="Top" />
        </Border>
        <Border Grid.Row="1" Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="16" Margin="12,4"
                BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="1">
            <Grid x:Name="MiddleHost" />
        </Border>
        <Border Grid.Row="2" Background="Transparent" Padding="8,0">
            <controls:BottomControlPanel x:Name="Bottom" />
        </Border>
    </Grid>
</UserControl>
