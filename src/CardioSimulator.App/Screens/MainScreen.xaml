<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CardioSimulator.App.Screens.MainScreen"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CardioSimulator.App.Controls">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="15*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="LightGray" Padding="8">
            <controls:TopControlPanel x:Name="Top" />
        </Border>
        <Border Grid.Row="1" Background="LightGray" Padding="8">
            <Grid x:Name="MiddleHost" />
        </Border>
        <Border Grid.Row="2" Background="LightGray" Padding="8">
            <controls:BottomControlPanel x:Name="Bottom" />
        </Border>
    </Grid>
</UserControl>
