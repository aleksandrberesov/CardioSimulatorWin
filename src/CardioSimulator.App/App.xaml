<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CardioSimulator.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ════════════════════════════════════════════════════════════════
                 App design tokens (single source of truth). The new UI pattern:
                 lavender page, white rounded panels, flat controls, green accent
                 on active/selected state. AppTheme.cs resolves these same keys for
                 code-behind, so XAML and C# share one palette. Values are tuned
                 against the reference mockups.
                 ════════════════════════════════════════════════════════════════ -->

            <!-- Core palette colors -->
            <Color x:Key="AccentColor">#FF33A06A</Color>
            <Color x:Key="AccentTintColor">#FFDCF1E6</Color>
            <Color x:Key="OnAccentColor">#FFFFFFFF</Color>
            <Color x:Key="PageBackgroundColor">#FFE8EAF4</Color>
            <Color x:Key="PanelBackgroundColor">#FFFFFFFF</Color>
            <Color x:Key="ControlFillColor">#FFEFF1F7</Color>
            <Color x:Key="ControlBorderColor">#FFE0E4EC</Color>
            <Color x:Key="HairlineColor">#FFE2E5EE</Color>
            <Color x:Key="HoverFillColor">#14808080</Color>
            <Color x:Key="TextPrimaryColor">#FF1B2430</Color>
            <Color x:Key="TextSecondaryColor">#FF5A6B82</Color>

            <!-- Matching brushes (referenced by {StaticResource ...Brush} in XAML) -->
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="AccentTintBrush" Color="{StaticResource AccentTintColor}" />
            <SolidColorBrush x:Key="OnAccentBrush" Color="{StaticResource OnAccentColor}" />
            <SolidColorBrush x:Key="PageBackgroundBrush" Color="{StaticResource PageBackgroundColor}" />
            <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}" />
            <SolidColorBrush x:Key="ControlFillBrush" Color="{StaticResource ControlFillColor}" />
            <SolidColorBrush x:Key="ControlBorderBrush" Color="{StaticResource ControlBorderColor}" />
            <SolidColorBrush x:Key="HairlineBrush" Color="{StaticResource HairlineColor}" />
            <SolidColorBrush x:Key="HoverFillBrush" Color="{StaticResource HoverFillColor}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />

            <!-- ── Make standard WinUI controls adopt the green accent ──────────
                 Override the framework accent color (and its light/dark ramp) plus
                 the derived accent fill brushes. This recolors accent buttons,
                 checked toggles, ComboBox/ListView selection, sliders, etc. across
                 every C#-built screen without touching control templates. -->
            <Color x:Key="SystemAccentColor">#FF33A06A</Color>
            <Color x:Key="SystemAccentColorLight1">#FF44B07A</Color>
            <Color x:Key="SystemAccentColorLight2">#FF5BBF8C</Color>
            <Color x:Key="SystemAccentColorLight3">#FF7FD0A6</Color>
            <Color x:Key="SystemAccentColorDark1">#FF2C8E5E</Color>
            <Color x:Key="SystemAccentColorDark2">#FF237A4F</Color>
            <Color x:Key="SystemAccentColorDark3">#FF1A6640</Color>

            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#E633A06A" />
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#CC33A06A" />

            <!-- Softer, rounder default corners for standard controls (modest, safe). -->
            <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
            <CornerRadius x:Key="OverlayCornerRadius">8</CornerRadius>
        </ResourceDictionary>
    </Application.Resources>
</Application>
